# Neo4j (read-only)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# MySQL (shared database)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=brn_admin_panel
DB_USER=
DB_PASSWORD=

# LLM Provider defaults (overridable per-request)
LITELLM_API_BASE=http://airouter.broadnet.app/v1
LITELLM_API_KEY=
FIREWORKS_API_BASE=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Authentication
X_API_KEY=              # same key as Response/Prompt services for S2S calls
JWT_SECRET=             # Base64-encoded HMAC-SHA256 secret (same as Gateway/Auth Service)

# Redis (for JWT token blacklist — same instance as Auth Service/Gateway)
REDIS_HOST=                     # leave empty to disable (direct JWT blacklist skipped in dev)
REDIS_PORT=6379
REDIS_DB=0

# Server
SERVER_PORT=8062
APP_ENV=dev                 # "production" disables Swagger docs (/review-api/docs)
